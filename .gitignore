.DS_Store
.obsidian/

# Generated skill/eval workspaces never belong in runtime entry roots.
.skill-workspaces/

# Tool runtime roots are deny-by-default. Only durable entry files and canonical
# skill directories are whitelisted below.
.claude/*
!.claude/organize.sh
!.claude/bin/
.claude/bin/*
!.claude/bin/organize-inbox-apply-duplicates
!.claude/bin/organize-inbox-apply-duplicates.cmd
!.claude/bin/organize-inbox-prepare
!.claude/bin/organize-inbox-prepare.cmd
!.claude/bin/organize-inbox-scan
!.claude/bin/organize-inbox-scan.cmd
!.claude/bin/safe-git-add
!.claude/bin/safe-git-add.cmd
!.claude/bin/safe-git-commit
!.claude/bin/safe-git-commit.cmd
!.claude/bin/safe-git-mv
!.claude/bin/safe-git-mv.cmd
!.claude/bin/safe-markitdown
!.claude/bin/safe-markitdown.cmd
!.claude/bin/safe-mkdir
!.claude/bin/safe-mkdir.cmd
!.claude/bin/safe-whisper
!.claude/bin/safe-whisper.cmd
!.claude/skills/
.claude/skills/*
!.claude/skills/optimize-vault/
!.claude/skills/optimize-vault/**
!.claude/skills/organize-inbox/
!.claude/skills/organize-inbox/**
!.claude/skills/setup-brain/
!.claude/skills/setup-brain/**

.agents/*
!.agents/skills/
.agents/skills/*
!.agents/skills/optimize-vault/
!.agents/skills/optimize-vault/**
!.agents/skills/organize-inbox/
!.agents/skills/organize-inbox/**

.codex/*
!.codex/skills/
.codex/skills/*
!.codex/skills/optimize-vault/
!.codex/skills/optimize-vault/**
!.codex/skills/organize-inbox/
!.codex/skills/organize-inbox/**
!.codex/skills/setup-brain/
!.codex/skills/setup-brain/**

.copilot/*
!.copilot/.github/
.copilot/.github/*
!.copilot/.github/plugin/
!.copilot/.github/plugin/plugin.json
!.copilot/skills/
.copilot/skills/*
!.copilot/skills/optimize-vault/
