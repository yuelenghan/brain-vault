#!/usr/bin/env python3
"""Run meditate scan with fixed report paths."""

from __future__ import annotations

import os
import subprocess
import sys
import tempfile
from pathlib import Path


SCRIPT = Path(".claude/skills/meditate/scripts/optimize_vault.py")
REPORT_DIR = Path(os.environ.get("MEDITATE_TEST_REPORT_DIR") or tempfile.gettempdir()).resolve()
JSON_REPORT = str(REPORT_DIR / "meditate.json")
MARKDOWN_REPORT = str(REPORT_DIR / "meditate.md")


def main(argv: list[str]) -> int:
    if argv:
        print("meditate-scan: arguments are not allowed", file=sys.stderr)
        return 2
    return subprocess.run(
        [
            "python3",
            str(SCRIPT),
            "--mode",
            "scan",
            "--json",
            JSON_REPORT,
            "--markdown",
            MARKDOWN_REPORT,
        ],
        check=False,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
