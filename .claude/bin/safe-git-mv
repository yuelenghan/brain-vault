#!/usr/bin/env python3
"""Safe git mv wrapper for brain-vault ingest work."""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path


ALLOWED_PREFIXES = ("Inbox/", "Projects/", "Areas/", "Resources/", "Archive/")


def valid_path(raw: str) -> bool:
    if raw.startswith("-"):
        return False
    path = Path(raw)
    if path.is_absolute() or ".." in path.parts:
        return False
    rel = path.as_posix()
    return any(rel.startswith(prefix) for prefix in ALLOWED_PREFIXES)


def main(argv: list[str]) -> int:
    if len(argv) != 2:
        print("safe-git-mv: expected source and destination", file=sys.stderr)
        return 2
    bad = [arg for arg in argv if not valid_path(arg)]
    if bad:
        print(f"safe-git-mv: disallowed path: {bad[0]}", file=sys.stderr)
        return 2
    return subprocess.run(["git", "mv", argv[0], argv[1]], check=False).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
