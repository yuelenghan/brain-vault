#!/usr/bin/env python3
"""Run the ingest scanner with fixed report paths."""

from __future__ import annotations

import subprocess
import sys
import tempfile
from pathlib import Path


SCRIPT = Path(".claude/skills/ingest/scripts/ingest.py")
REPORT_DIR = Path(tempfile.gettempdir()).resolve()
JSON_REPORT = REPORT_DIR / "ingest.json"
MARKDOWN_REPORT = REPORT_DIR / "ingest.md"


def main(argv: list[str]) -> int:
    if argv:
        print("ingest-scan: arguments are not allowed", file=sys.stderr)
        return 2
    return subprocess.run(
        [
            sys.executable,
            str(SCRIPT),
            "--mode",
            "scan",
            "--json",
            str(JSON_REPORT),
            "--markdown",
            str(MARKDOWN_REPORT),
        ],
        check=False,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
