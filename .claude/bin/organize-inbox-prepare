#!/usr/bin/env python3
"""Run organize-inbox prepare with fixed report paths."""

from __future__ import annotations

import subprocess
import sys
import tempfile
from pathlib import Path


SCRIPT = Path(".claude/skills/organize-inbox/scripts/organize_inbox.py")
REPORT_DIR = Path(tempfile.gettempdir()).resolve()
JSON_REPORT = REPORT_DIR / "organize-inbox.json"
MARKDOWN_REPORT = REPORT_DIR / "organize-inbox.md"


def main(argv: list[str]) -> int:
    if argv:
        print("organize-inbox-prepare: arguments are not allowed", file=sys.stderr)
        return 2
    return subprocess.run(
        [
            sys.executable,
            str(SCRIPT),
            "--mode",
            "prepare",
            "--json",
            str(JSON_REPORT),
            "--markdown",
            str(MARKDOWN_REPORT),
        ],
        check=False,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
