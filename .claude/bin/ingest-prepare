#!/usr/bin/env python3
"""Run ingest prepare with fixed report paths."""

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path


SCRIPT = Path(".claude/skills/ingest/scripts/ingest.py")
REPORT_DIR = Path(os.environ.get("INGEST_TEST_REPORT_DIR", "/tmp")).resolve()
JSON_REPORT = str(REPORT_DIR / "ingest.json")
MARKDOWN_REPORT = str(REPORT_DIR / "ingest.md")


def main(argv: list[str]) -> int:
    if argv:
        print("ingest-prepare: arguments are not allowed", file=sys.stderr)
        return 2
    return subprocess.run(
        [
            "python3",
            str(SCRIPT),
            "--mode",
            "prepare",
            "--json",
            JSON_REPORT,
            "--markdown",
            MARKDOWN_REPORT,
        ],
        check=False,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
