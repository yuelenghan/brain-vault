#!/usr/bin/env python3
"""Safely convert a vault Inbox document or screenshot to Markdown."""

from __future__ import annotations

import os
import subprocess
import sys
import tempfile
from pathlib import Path

try:
    from PIL import Image, UnidentifiedImageError
except ImportError:
    Image = None
    UnidentifiedImageError = Exception


TRUSTED_CWD = "/usr/bin"
IMAGE_EXTENSIONS = {".jpeg", ".jpg", ".png", ".webp"}


def fail(message: str) -> int:
    print(f"safe-markitdown: {message}", file=sys.stderr)
    return 2


def clean_environment() -> dict[str, str]:
    allowed = {
        "HOME",
        "LANG",
        "LC_ALL",
        "LC_CTYPE",
        "PATH",
        "SYSTEMROOT",
        "TMPDIR",
        "VAULT",
        "WINDIR",
    }
    env = {key: value for key, value in os.environ.items() if key in allowed}
    env.pop("PYTHONHOME", None)
    env.pop("PYTHONPATH", None)
    return env


def resolve_vault() -> Path:
    if os.environ.get("VAULT"):
        return Path(os.environ["VAULT"]).resolve()
    return Path.cwd().resolve()


def write_image_markdown(candidate: Path, temp_path: Path) -> int:
    if Image is None:
        return fail("Pillow is not installed")

    try:
        with Image.open(candidate) as image:
            image.load()
            image_format = image.format or candidate.suffix.lstrip(".").upper()
            width, height = image.size
    except UnidentifiedImageError:
        return fail("image file is not readable")
    except OSError as exc:
        return fail(f"failed to read image: {exc}")

    temp_path.write_text(
        f"# {candidate.stem}\n\n"
        f"> 截图笔记占位，原始文件：`Inbox/{candidate.name}`。\n\n"
        "## 图片信息\n\n"
        f"- 文件：`Inbox/{candidate.name}`\n"
        f"- 格式：{image_format}\n"
        f"- 尺寸：{width} × {height}\n\n"
        "## 待整理\n\n"
        "请结合原始截图内容提炼主题、关键信息和后续动作。\n",
        encoding="utf-8",
    )
    return 0


def run_markitdown(candidate: Path, temp_path: Path, env: dict[str, str]) -> int:
    command = ["markitdown", str(candidate), "-o", str(temp_path)]
    try:
        completed = subprocess.run(
            command,
            check=False,
            cwd=TRUSTED_CWD,
            env=env,
        )
    except OSError as exc:
        print(f"safe-markitdown: failed to execute markitdown: {exc}", file=sys.stderr)
        return 127
    return completed.returncode


def main(argv: list[str]) -> int:
    if len(argv) != 2:
        return fail("expected exactly one relative path under Inbox")

    raw = argv[1]
    if raw.startswith("-"):
        return fail("path must not start with '-'")

    input_path = Path(raw)
    if input_path.is_absolute() or ".." in input_path.parts:
        return fail("path must be relative and must not contain '..'")

    vault = resolve_vault()
    inbox = (vault / "Inbox").resolve()
    candidate = (vault / input_path).resolve()

    if not str(candidate).startswith(str(inbox) + os.sep):
        return fail("path must resolve inside Inbox")
    if not candidate.is_file():
        return fail("path is not a file")
    if candidate.is_symlink():
        return fail("symlink input is not allowed")

    out_name = candidate.with_suffix(".md").name
    output = inbox / out_name
    if os.path.lexists(output):
        return fail(f"output already exists: Inbox/{out_name}")

    fd, temp_name = tempfile.mkstemp(
        prefix=f".{candidate.stem}.",
        suffix=".md.tmp",
        dir=inbox,
        text=True,
    )
    os.close(fd)
    temp_path = Path(temp_name)

    try:
        env = clean_environment()
        if candidate.suffix.lower() in IMAGE_EXTENSIONS:
            return_code = write_image_markdown(candidate, temp_path)
        else:
            return_code = run_markitdown(candidate, temp_path, env)

        if return_code != 0:
            return return_code
        if not temp_path.is_file() or temp_path.is_symlink() or temp_path.stat().st_size == 0:
            return fail("conversion output is empty or invalid")
        if os.path.lexists(output):
            return fail(f"output appeared during conversion: Inbox/{out_name}")
        os.replace(temp_path, output)
    finally:
        try:
            if temp_path.exists() or temp_path.is_symlink():
                temp_path.unlink()
        except OSError:
            pass

    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
