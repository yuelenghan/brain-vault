#!/usr/bin/env python3
"""Finalize the latest meditate log entry with a commit hash."""

from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path


SCRIPT = Path(".claude/skills/meditate/scripts/optimize_vault.py")
COMMIT_RE = re.compile(r"^[0-9a-f]{40}$")


def main(argv: list[str]) -> int:
    if len(argv) != 1 or not COMMIT_RE.match(argv[0]):
        print("meditate-finalize-log: expected one 40-character lowercase commit hash", file=sys.stderr)
        return 2
    return subprocess.run(
        [
            "python3",
            str(SCRIPT),
            "--mode",
            "finalize-log",
            "--commit",
            argv[0],
        ],
        check=False,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
