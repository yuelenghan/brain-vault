#!/usr/bin/env python3
"""Run ingest duplicate archival with fixed report paths."""

from __future__ import annotations

import re
import subprocess
import sys
import tempfile
from pathlib import Path


SCRIPT = Path(".claude/skills/ingest/scripts/ingest.py")
REPORT_DIR = Path(tempfile.gettempdir()).resolve()
JSON_REPORT = REPORT_DIR / "ingest.json"
MARKDOWN_REPORT = REPORT_DIR / "ingest.md"
DATE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}(?: \d{2}:\d{2})?$")


def main(argv: list[str]) -> int:
    if len(argv) != 1 or not DATE_RE.match(argv[0]):
        print("ingest-apply-duplicates: expected one YYYY-MM-DD or YYYY-MM-DD HH:MM date", file=sys.stderr)
        return 2
    return subprocess.run(
        [
            sys.executable,
            str(SCRIPT),
            "--mode",
            "apply-duplicates",
            "--json",
            str(JSON_REPORT),
            "--markdown",
            str(MARKDOWN_REPORT),
            "--date",
            argv[0],
        ],
        check=False,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
