#!/usr/bin/env python3
"""Run ingest duplicate archival with fixed report paths."""

from __future__ import annotations

import os
import re
import subprocess
import sys
from pathlib import Path


SCRIPT = Path(".claude/skills/ingest/scripts/ingest.py")
REPORT_DIR = Path(os.environ.get("INGEST_TEST_REPORT_DIR", "/tmp")).resolve()
JSON_REPORT = str(REPORT_DIR / "ingest.json")
MARKDOWN_REPORT = str(REPORT_DIR / "ingest.md")
DATE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}(?: \d{2}:\d{2})?$")


def main(argv: list[str]) -> int:
    if len(argv) != 1 or not DATE_RE.match(argv[0]):
        print("ingest-apply-duplicates: expected one YYYY-MM-DD or YYYY-MM-DD HH:MM date", file=sys.stderr)
        return 2
    return subprocess.run(
        [
            "python3",
            str(SCRIPT),
            "--mode",
            "apply-duplicates",
            "--json",
            JSON_REPORT,
            "--markdown",
            MARKDOWN_REPORT,
            "--date",
            argv[0],
        ],
        check=False,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
